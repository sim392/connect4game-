%{
#include <stdio.h>
#include <string.h>
 
int line_no = 1;
 
void print_token(const char *name, const char *lexeme) {
    printf("<%s, \"%s\", line %d>\n", name, lexeme, line_no);
}
 
%}
 
CONST    [A-Za-z_][A-Za-z0-9_]*
INT      [0-9]+
FRACT    [0-9]*"."[0-9]+|[0-9]+"."[0-9]*
WS       [ \t\r]+
 
%%
 
 
{WS}               { /* ignore spaces/tabs */ }
\n                 { line_no++; }
 
 
"//".*                         { print_token("COMMENT:", yytext); }
"/*"([^*]|\*+[^*/])*\*+"/"    { print_token("COMMENT:", yytext); }
 
 
"\""                { print_token("DOUBLE QUOTE", yytext); }
"\'"                { print_token("SINGLE QUOTE", yytext); }
"\\\""              { print_token("ESCAPED_QUOTE", yytext); }
 
 
 
"int"               { print_token("KEYWORD", yytext); }
