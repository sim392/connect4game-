<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Wareef Dashboard (HTML)</title>

  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

  <style>
    :root{
      --bg:#f6f8fb;
      --card:#ffffff;
      --text:#0f172a;
      --muted:#64748b;
      --line:#e2e8f0;
      --shadow: 0 10px 30px rgba(15,23,42,.06);
      --radius: 18px;
      --green:#16a34a;
      --green-2:#e9f7ef;
      --amber:#f59e0b;
      --amber-2:#fff7ed;
      --rose:#fb7185;
      --rose-2:#fff1f2;
      --blue:#0ea5e9;
      --blue-2:#ecfeff;
      --dark:#0b1220;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Apple Color Emoji","Segoe UI Emoji";
      background:var(--bg);
      color:var(--text);
    }
    a{color:inherit}
    .hidden{display:none !important;}

    .app{
      max-width: 1400px;
      margin: 0 auto;
      display:flex;
      min-height: 100vh;
      padding: 16px;
      gap: 16px;
    }

    /* Sidebar */
    .sidebar{
      width: 260px;
      flex: 0 0 260px;
    }
    .panel{
      background:var(--card);
      border:1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }
    .sidebar .panel{padding:16px;}

    .brand{
      display:flex;
      gap:12px;
      align-items:center;
    }

    /* UPDATED logo to show your base64 image */
    .logo{
      width:40px;
      height:40px;
      border-radius: 12px;
      background: #ffffff;
      border: 1px solid var(--line);
      display:flex;
      align-items:center;
      justify-content:center;
      overflow:hidden;
      flex: 0 0 40px;
    }
    .logo img{
      width: 100%;
      height: 100%;
      object-fit: cover;
      display:block;
    }
    .dot{width:14px;height:14px;border-radius:50%;background:#0f9d58;} /* kept (unused now) */

    .brand h1{font-size:14px;margin:0;font-weight:800;letter-spacing:.2px}
    .brand p{font-size:12px;margin:2px 0 0;color:var(--muted)}

    .sidebar-top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      margin-top: 14px;
    }
    .sidebar-top .title{font-size:12px;font-weight:700;color:#475569}

    .pill{
      display:inline-flex;
      align-items:center;
      border:1px solid var(--line);
      border-radius:999px;
      padding:6px 10px;
      font-size:12px;
      font-weight:700;
      line-height: 1;
      white-space:nowrap;
    }
    .pill.success{background:var(--green-2);border-color:#c9efd8;color:#0f7a3a;}
    .pill.warning{background:var(--amber-2);border-color:#fed7aa;color:#b45309;}
    .pill.danger{background:var(--rose-2);border-color:#fecdd3;color:#be123c;}
    .pill.info{background:var(--blue-2);border-color:#bae6fd;color:#0369a1;}

    .nav{
      margin-top: 10px;
      display:flex;
      flex-direction:column;
      gap:6px;
    }
    .nav button{
      border:0;
      background:transparent;
      text-align:left;
      padding:10px 12px;
      border-radius: 14px;
      font-size:14px;
      color:#334155;
      cursor:pointer;
    }
    .nav button:hover{background:#f1f5f9;}
    .nav button.active{
      background:#eafaf0;
      color:#0f7a3a;
      border:1px solid #c9efd8;
    }

    /* Main */
    .main{
      flex:1;
      display:flex;
      flex-direction:column;
      gap:16px;
    }
    .topbar{
      display:flex;
      align-items:center;
      gap:12px;
    }
    .search{
      flex:1;
      position:relative;
    }
    .search input{
      width:100%;
      border-radius: var(--radius);
      border:1px solid var(--line);
      background:var(--card);
      box-shadow: var(--shadow);
      padding: 14px 14px;
      font-size: 14px;
      outline:none;
    }
    .btn{
      border-radius: var(--radius);
      border:1px solid var(--line);
      background: var(--card);
      box-shadow: var(--shadow);
      padding: 12px 14px;
      font-weight:800;
      font-size: 13px;
      cursor:pointer;
      color:#334155;
    }
    .btn:hover{background:#f8fafc;}
    .btn.primary{
      background:#eafaf0;
      border-color:#c9efd8;
      color:#0f7a3a;
    }
    .btn.dark{
      background: var(--dark);
      color:white;
      border-color: transparent;
    }

    .metrics{
      display:grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
    }
    .metric{ padding: 16px; }
    .metric .label{font-size:12px;color:var(--muted);font-weight:700;}
    .metric .row{display:flex;align-items:center;justify-content:space-between;margin-top:10px;}
    .metric .value{font-size:26px;font-weight:900;letter-spacing:-.3px;}

    .grid{
      display:grid;
      grid-template-columns: 2fr 1fr;
      gap: 16px;
    }
    .card{ padding: 16px; }
    .card-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 12px;
      margin-bottom: 10px;
    }
    .card-title{font-size:14px;font-weight:900;}
    .card-right{font-size:12px;color:var(--muted);font-weight:700;}
    .chart-wrap{ height: 260px; margin-top: 6px; }
    canvas{max-width:100%}

    .insights .item, .notifications .item{
      border:1px solid var(--line);
      border-radius: 16px;
      padding: 14px;
      background: white;
    }
    .insights .item + .item, .notifications .item + .item{margin-top: 10px;}
    .item-top{display:flex;align-items:center;justify-content:space-between;gap:10px;}
    .item-title{font-size:14px;font-weight:900;}
    .item-sub{font-size:12px;color:var(--muted);margin-top:6px;font-weight:600;}

    .bottom{
      display:grid;
      grid-template-columns: 2fr 1fr;
      gap:16px;
    }
    table{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      overflow:hidden;
      border-radius: 16px;
      border:1px solid var(--line);
    }
    thead th{
      background:#f8fafc;
      color:#475569;
      font-size:12px;
      font-weight:900;
      padding: 12px 12px;
      text-align:left;
    }
    tbody td{
      padding: 12px 12px;
      border-top:1px solid var(--line);
      font-size:13px;
      color:#334155;
      font-weight:600;
    }
    tbody td:first-child{font-weight:900;color:#0f172a;}

    .two-charts{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-top: 14px;
    }
    .mini-chart{
      border:1px solid var(--line);
      border-radius: 16px;
      padding: 12px;
      background: white;
    }
    .mini-chart .t{font-weight:900;font-size:13px;margin-bottom:8px;}
    .mini-chart .h{height:220px;}

    /* Login */
    .login-wrap{
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding: 16px;
    }
    .login{
      width: 420px;
      padding: 18px;
    }
    .login h2{margin:14px 0 4px;font-size:18px;}
    .login p{margin:0;color:var(--muted);font-size:13px;font-weight:600;}
    .field{margin-top:12px;}
    .field label{display:block;font-size:12px;font-weight:900;color:#475569;margin-bottom:6px;}
    .field input{
      width:100%;
      border-radius: var(--radius);
      border:1px solid var(--line);
      padding: 12px 14px;
      font-size:14px;
      outline:none;
      background:white;
    }
    .error{
      margin-top: 10px;
      border-radius: 16px;
      border:1px solid #fecdd3;
      background:#fff1f2;
      color:#be123c;
      padding: 10px 12px;
      font-weight:800;
      font-size:13px;
    }

    @media (max-width: 1100px){
      .metrics{grid-template-columns: repeat(2, minmax(0,1fr));}
      .grid{grid-template-columns: 1fr;}
      .bottom{grid-template-columns: 1fr;}
      .two-charts{grid-template-columns: 1fr;}
      .sidebar{display:none;}
      .app{padding: 12px;}
    }
  </style>
</head>

<body>
  <script>
    // put the base64 image in one place so we can reuse it
    const WAREEF_LOGO_SRC =
      'data:image/png;base64,';
  </script>

  <!-- LOGIN -->
  <section id="loginPage" class="login-wrap hidden">
    <div class="panel login">
      <div class="brand">
        <div class="logo" aria-label="Wareef logo">
          <img id="logoLogin" alt="WAREEF logo" />
        </div>
        <div>
          <h1>WAREEF</h1>
          <p>Sign in to continue</p>
        </div>
      </div>

      <h2>Login</h2>
      <p>Demo login: any non-empty email/password.</p>

      <form id="loginForm">
        <div class="field">
          <label>Email</label>
          <input id="email" type="email" placeholder="admin@wareef.com" value="admin@wareef.com" />
        </div>
        <div class="field">
          <label>Password</label>
          <input id="password" type="password" placeholder="••••••••" value="password" />
        </div>
        <div id="loginError" class="error hidden">Please enter email and password.</div>
        <button class="btn dark" style="margin-top:14px;width:100%;" type="submit">Login</button>
      </form>
    </div>
  </section>

  <!-- DASHBOARD -->
  <section id="dashboardPage" class="hidden">
    <div class="app">
      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="panel">
          <div class="brand">
            <div class="logo" aria-label="Wareef logo">
              <img id="logoSidebar" alt="WAREEF logo" />
            </div>
            <div>
              <h1>WAREEF</h1>
              <p>Operations Dashboard</p>
            </div>
          </div>

          <div class="sidebar-top">
            <div class="title">Overview</div>
            <span class="pill success">Live</span>
          </div>

          <div class="nav" id="nav">
            <button class="active" data-key="overview">Overview</button>
            <button data-key="sales">Sales</button>
            <button data-key="inventory">Inventory</button>
            <button data-key="customers">Customers</button>
            <button data-key="reports">Reports</button>
            <button data-key="settings">Settings</button>
          </div>
        </div>
      </aside>

      <!-- Main -->
      <main class="main">
        <!-- Topbar -->
        <div class="topbar">
          <div class="search">
            <input placeholder="Search orders, customers, SKUs..." />
          </div>
          <button class="btn">Export</button>
          <button class="btn primary">Refresh</button>
          <button class="btn dark" id="logoutBtn">Logout</button>
        </div>

        <!-- Metrics -->
        <div class="metrics">
          <div class="panel metric">
            <div class="label">Total Revenue</div>
            <div class="row">
              <div class="value">$128,430</div>
              <span class="pill success">+12.4%</span>
            </div>
          </div>
          <div class="panel metric">
            <div class="label">Orders</div>
            <div class="row">
              <div class="value">2,348</div>
              <span class="pill success">+4.1%</span>
            </div>
          </div>
          <div class="panel metric">
            <div class="label">Returns</div>
            <div class="row">
              <div class="value">86</div>
              <span class="pill warning">+1.2%</span>
            </div>
          </div>
          <div class="panel metric">
            <div class="label">Alerts</div>
            <div class="row">
              <div class="value">3</div>
              <span class="pill danger">Needs review</span>
            </div>
          </div>
        </div>

        <!-- Mid grid -->
        <div class="grid">
          <!-- Weekly Performance (line) -->
          <div class="panel card">
            <div class="card-head">
              <div class="card-title">Weekly Performance</div>
              <div class="card-right">Last 7 days</div>
            </div>
            <div class="chart-wrap">
              <canvas id="lineChart"></canvas>
            </div>
          </div>

          <!-- Quick Insights -->
          <div class="panel card insights">
            <div class="card-head">
              <div class="card-title">Quick Insights</div>
              <div class="card-right">Auto-generated</div>
            </div>

            <div class="item">
              <div class="item-top">
                <div class="item-title">Revenue trending up</div>
                <span class="pill success">Good</span>
              </div>
              <div class="item-sub">Weekend performance improved vs last week.</div>
            </div>

            <div class="item">
              <div class="item-top">
                <div class="item-title">Returns slightly higher</div>
                <span class="pill warning">Watch</span>
              </div>
              <div class="item-sub">Check top 3 SKUs with frequent returns.</div>
            </div>

            <div class="item">
              <div class="item-top">
                <div class="item-title">Low stock warning</div>
                <span class="pill info">Action</span>
              </div>
              <div class="item-sub">4 items below reorder threshold.</div>
            </div>
          </div>
        </div>

        <!-- Bottom grid -->
        <div class="bottom">
          <!-- Latest Orders + charts -->
          <div class="panel card">
            <div class="card-head">
              <div class="card-title">Latest Orders</div>
              <div class="card-right">5 items</div>
            </div>

            <table>
              <thead>
                <tr>
                  <th>Order</th>
                  <th>Customer</th>
                  <th>Amount</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>WR-10492</td><td>Al-Nour Co.</td><td>$1,840.00</td>
                  <td><span class="pill success">Completed</span></td>
                </tr>
                <tr>
                  <td>WR-10493</td><td>Riyadh Mart</td><td>$320.00</td>
                  <td><span class="pill warning">Pending</span></td>
                </tr>
                <tr>
                  <td>WR-10494</td><td>Green Valley</td><td>$910.00</td>
                  <td><span class="pill success">Completed</span></td>
                </tr>
                <tr>
                  <td>WR-10495</td><td>Sahara Trading</td><td>$120.00</td>
                  <td><span class="pill danger">Issue</span></td>
                </tr>
                <tr>
                  <td>WR-10496</td><td>Al-Faisal Group</td><td>$2,630.00</td>
                  <td><span class="pill success">Completed</span></td>
                </tr>
              </tbody>
            </table>

            <div class="two-charts">
              <div class="mini-chart">
                <div class="t">Units by Category</div>
                <div class="h"><canvas id="barChart"></canvas></div>
              </div>
              <div class="mini-chart">
                <div class="t">Order Status Mix</div>
                <div class="h"><canvas id="pieChart"></canvas></div>
              </div>
            </div>
          </div>

          <!-- Notifications -->
          <div class="panel card notifications">
            <div class="card-head">
              <div class="card-title">Notifications</div>
              <div class="card-right">2</div>
            </div>

            <div class="item">
              <div class="item-top">
                <div class="item-title">SKU WRF-221 low stock</div>
                <span class="pill info">Inventory</span>
              </div>
              <div class="item-sub">Only 12 units remaining.</div>
            </div>

            <div class="item">
              <div class="item-top">
                <div class="item-title">Failed payment</div>
                <span class="pill warning">Billing</span>
              </div>
              <div class="item-sub">Order WR-10495 needs follow-up.</div>
            </div>

            <div style="margin-top:12px;font-size:12px;color:var(--muted);font-weight:700;">
              Active section:
              <span id="activeSection" style="color:#334155;font-weight:900;">overview</span>
            </div>
          </div>
        </div>
      </main>
    </div>
  </section>

  <script>
    // Apply the base64 logo to both login + sidebar images
    const logoLogin = document.getElementById("logoLogin");
    const logoSidebar = document.getElementById("logoSidebar");
    if (logoLogin) logoLogin.src = WAREEF_LOGO_SRC;
    if (logoSidebar) logoSidebar.src = WAREEF_LOGO_SRC;

    // ---------------------------
    // Simple demo auth
    // ---------------------------
    const loginPage = document.getElementById("loginPage");
    const dashboardPage = document.getElementById("dashboardPage");

    function showApp() {
      const authed = localStorage.getItem("demo_authed") === "true";
      if (authed) {
        loginPage.classList.add("hidden");
        dashboardPage.classList.remove("hidden");
        initChartsOnce();
      } else {
        dashboardPage.classList.add("hidden");
        loginPage.classList.remove("hidden");
      }
    }

    document.getElementById("loginForm").addEventListener("submit", (e) => {
      e.preventDefault();
      const email = document.getElementById("email").value.trim();
      const pass = document.getElementById("password").value.trim();
      const err = document.getElementById("loginError");

      if (!email || !pass) {
        err.classList.remove("hidden");
        return;
      }
      err.classList.add("hidden");
      localStorage.setItem("demo_authed", "true");
      showApp();
    });

    document.getElementById("logoutBtn").addEventListener("click", () => {
      localStorage.removeItem("demo_authed");
      location.reload();
    });

    // ---------------------------
    // Sidebar active state
    // ---------------------------
    const nav = document.getElementById("nav");
    const activeSection = document.getElementById("activeSection");

    nav.addEventListener("click", (e) => {
      if (e.target.tagName !== "BUTTON") return;
      [...nav.querySelectorAll("button")].forEach(b => b.classList.remove("active"));
      e.target.classList.add("active");
      activeSection.textContent = e.target.dataset.key || "overview";
    });

    // ---------------------------
    // Charts (Chart.js)
    // ---------------------------
    let chartsInitialized = false;
    let lineChart, barChart, pieChart;

    function initChartsOnce() {
      if (chartsInitialized) return;
      chartsInitialized = true;

      // LINE
      const lineCtx = document.getElementById("lineChart");
      lineChart = new Chart(lineCtx, {
        type: "line",
        data: {
          labels: ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"],
          datasets: [{
            label: "Revenue",
            data: [12000,14800,13100,16200,17000,20500,18900],
            tension: 0.35,
            borderWidth: 3,
            pointRadius: 0
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: (ctx) => " " + new Intl.NumberFormat(undefined, {style:"currency", currency:"USD"}).format(ctx.parsed.y)
              }
            }
          },
          scales: {
            x: { grid: { display: false }, ticks: { font: { weight: "700" } } },
            y: {
              grid: { color: "#e2e8f0" },
              ticks: {
                font: { weight: "700" },
                callback: (v) => "$" + (v/1000) + "k"
              }
            }
          }
        }
      });

      // BAR
      const barCtx = document.getElementById("barChart");
      barChart = new Chart(barCtx, {
        type: "bar",
        data: {
          labels: ["Beverage","Snacks","Household","Personal","Dairy"],
          datasets: [{ label: "Units", data: [420,610,280,360,510], borderWidth: 1 }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { grid: { display: false }, ticks: { font: { weight: "700" } } },
            y: { grid: { color: "#e2e8f0" }, ticks: { font: { weight: "700" } } }
          }
        }
      });

      // PIE
      const pieCtx = document.getElementById("pieChart");
      pieChart = new Chart(pieCtx, {
        type: "pie",
        data: { labels: ["Completed","Pending","Issue"], datasets: [{ data: [62,24,14] }] },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { position: "bottom", labels: { font: { weight: "700" } } } }
        }
      });
    }

    // boot
    showApp();
  </script>
</body>
</html>
